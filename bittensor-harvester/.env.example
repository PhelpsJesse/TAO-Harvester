# Bittensor Harvester Configuration
# Copy this file to .env and fill in your values
# .env is NOT committed to git (secrets file)

# === Substrate RPC ===
SUBSTRATE_RPC_URL=http://localhost:9933
NETUID=1

# === Harvest Policy ===
HARVEST_FRACTION=0.5
MIN_HARVEST_THRESHOLD_TAO=0.1
MAX_HARVEST_PER_RUN_TAO=10.0
MAX_HARVEST_PER_DAY_TAO=50.0

# === Harvest Destination (Allowlist) ===
# This address MUST be in the subnet's harvest allowlist
HARVEST_DESTINATION_ADDRESS=5YOUR_ADDRESS_HERE

# === Wallet / Keys ===
# Use either SEED (preferred for security) or address
HARVESTER_WALLET_SEED=
HARVESTER_WALLET_ADDRESS=5EWvVeoscCk6atHj5ZncAqx7u7QtfvHvCifgKyysPsYbMfmh

# === Kraken Integration (Optional) ===
# For automated TAO → USD sales
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_DEPOSIT_ADDRESS=

# === Taostats API (Optional) ===
# For retrieving earnings statistics
# Get your API key from: https://taostats.io
TAOSTATS_API_KEY=tao-40546b90-9bb7-44a8-bad9-4110f9f809fd:0700a759

# === Withdrawal Settings ===
MIN_WITHDRAWAL_THRESHOLD_USD=100.0
MAX_WITHDRAWAL_PER_WEEK_USD=500.0
WITHDRAWAL_DESTINATION_ACCOUNT=

# === Database ===
DB_PATH=harvester.db

# === Logging ===
LOG_LEVEL=INFO
