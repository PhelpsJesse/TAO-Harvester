# TAO Harvester Configuration Template
# Copy this file to .env and fill in your values.
# Do not commit real secrets or private keys.

# === Safety Controls (legacy pipeline) ===
EXECUTION_ENABLED=false
TAOSTATS_ENABLED=true
ENABLE_HARVEST=false

# === Network / RPC ===
ARCHIVE_RPC_URL=wss://archive.chain.opentensor.ai:443
SUBSTRATE_RPC_URL=https://lite.chain.opentensor.ai
NETUID=1
SUBNET_LIST=

# === Wallet / Validators ===
VALIDATOR_HOTKEYS=
HARVESTER_WALLET_SEED=
HARVESTER_WALLET_ADDRESS=

# === Harvest Policy (legacy + v2) ===
HARVEST_FRACTION=0.5
MIN_HARVEST_THRESHOLD_TAO=0.1
MIN_HARVEST_ALPHA=1.0
MAX_HARVEST_PER_RUN_TAO=10.0
MAX_HARVEST_TAO_PER_RUN=25.0
MAX_HARVEST_PER_DAY_TAO=50.0
MAX_HARVEST_TAO_PER_DAY=100.0
TRANSFER_BATCH_THRESHOLD_TAO=2.0
HARVEST_DESTINATION_ADDRESS=5YOUR_ALLOWLISTED_ADDRESS_HERE

# === Taostats ===
TAOSTATS_API_KEY=tao-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxx
TAOSTATS_BASE_URL=https://api.taostats.io

# === Kraken (optional) ===
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_DEPOSIT_ADDRESS=
KRAKEN_DEPOSIT_WHITELIST=

# === OpenClaw VPS Handoff (Tier 3 pull model) ===
# These values are for local-machine retrieval of OpenClaw-generated handoff files.
# Keep real values only in local .env; do not commit secrets or private key material.
OPENCLAW_SSH_HOST=
OPENCLAW_SSH_PORT=22
OPENCLAW_SSH_USER=
OPENCLAW_SSH_KEY_PATH=
OPENCLAW_HANDOFF_REMOTE_DIR=/opt/harvester/handoff
OPENCLAW_HANDOFF_LOCAL_DIR=handoff
OPENCLAW_DB_REMOTE_PATH=/opt/harvester/data/harvester_v2.db
OPENCLAW_DB_LOCAL_PATH=v2/data/openclaw_latest.db

# === Withdrawal Settings ===
MIN_WITHDRAWAL_THRESHOLD_USD=100.0
MAX_WITHDRAWAL_PER_WEEK_USD=500.0
WITHDRAWAL_DESTINATION_ACCOUNT=

# === Storage / Runtime ===
DB_PATH=harvester.db
V2_DB_PATH=v2/data/harvester_v2.db
DRY_RUN=true
CATCHUP_MISSED_DAYS=true
LOG_LEVEL=INFO
