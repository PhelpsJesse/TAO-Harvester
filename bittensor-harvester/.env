# Bittensor Harvester Configuration
# Copy this file to .env and fill in your values
# .env is NOT committed to git (secrets file)

# === SAFETY CONTROLS ===
# CRITICAL: Master kill switches - keep these FALSE unless you want to execute real transactions
EXECUTION_ENABLED=false
TAOSTATS_ENABLED=true
ENABLE_HARVEST=false

# === Archive RPC ===
# Used for: Transaction submission (alpha→TAO swaps), historical balance queries
# Public archive endpoint with full block history since inception
ARCHIVE_RPC_URL=wss://archive.chain.opentensor.ai:443
NETUID=1

# === Subnet List ===
# Comma-separated list of all subnets with alpha holdings for reporting
# Sourced from Taostats: https://taostats.io/account/5EWvVeoscCk6atHj5ZncAqx7u7QtfvHvCifgKyysPsYbMfmh
SUBNET_LIST=

HARVESTER_WALLET_ADDRESS=5EWvVeoscCk6atHj5ZncAqx7u7QtfvHvCifgKyysPsYbMfmh

# === Kraken Integration (Optional) ===
# For automated TAO → USD sales
KRAKEN_API_KEY=d0wXfZ5Ed2c7CsOW62cQTStdpYWUvTt7+H+Su6UocBTygcUZvOxgogVl
KRAKEN_API_SECRET=tjPKK0/Nqf98cTDpAPVyLCmyxCVCECL/RnbIYK3cpQGGEcbzvdz3YiOwJ4KD1IocWcF1AxMLhSnSwC9O5nY4Pw==
KRAKEN_DEPOSIT_ADDRESS=5DyUBmjQ1fY27NxvBV9ryFe1vzEcCUWTt6ug9LyBnZg7bthw

# === Taostats API (Optional) ===
# For retrieving earnings statistics
# Get your API key from: https://taostats.io
TAOSTATS_API_KEY=tao-92b8a4fb-a2c1-4db1-aba0-72af48c390ca:4b19a63f


# === Withdrawal Settings ===
MIN_WITHDRAWAL_THRESHOLD_USD=15.0
MAX_WITHDRAWAL_PER_WEEK_USD=500.0
WITHDRAWAL_DESTINATION_ACCOUNT=

# === Database ===
DB_PATH=harvester.db

# === Logging ===
LOG_LEVEL=INFO
